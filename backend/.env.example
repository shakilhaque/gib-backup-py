# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql://backup_user:backup_pass@postgres:5432/backup_db

# SQLite (development / single-node)
# DATABASE_URL=sqlite:///./backups.db

# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# ──────────────────────────────────────────────
# Backup storage
# ──────────────────────────────────────────────
BACKUP_BASE_DIR=backups

# ──────────────────────────────────────────────
# SSH connection timeouts (seconds)
# ──────────────────────────────────────────────
SSH_TIMEOUT=30
SSH_BANNER_TIMEOUT=60
SSH_AUTH_TIMEOUT=30

# ──────────────────────────────────────────────
# FTP defaults
# ──────────────────────────────────────────────
DEFAULT_FTP_IP=10.69.10.11

# ──────────────────────────────────────────────
# Security: Fernet key for encrypting stored passwords
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ──────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_a_real_fernet_key_here
