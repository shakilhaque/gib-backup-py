# ══════════════════════════════════════════════════════════════
#  GIB Backup System – Production Environment Variables
#
#  INSTRUCTIONS:
#    1. Copy this file:   cp .env.prod.example .env
#    2. Fill in your real values below
#    3. Generate SECRET_KEY using the command shown below
#    4. Run:  docker compose -f docker-compose.prod.yml up -d --build
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL Credentials ──────────────────────────────────
POSTGRES_USER=backup_user
POSTGRES_PASSWORD=backup
POSTGRES_DB=backup_db

# ── Secret Key (for encrypting stored credentials) ──────────
# Generate with:
#   docker run --rm python:3.12-slim python -c \
#     "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=2GW2X3v0en92ME22QEbrWNbRjlDKobiOjPEjv1PKFfk=

# ── SSH Connection Timeouts (seconds) ───────────────────────
SSH_TIMEOUT=30
SSH_BANNER_TIMEOUT=60
SSH_AUTH_TIMEOUT=30

# ── FTP Default Server IP ───────────────────────────────────
DEFAULT_FTP_IP=10.69.10.11
